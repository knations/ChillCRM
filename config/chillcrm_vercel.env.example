# CHILLCRM Vercel staging environment template.
# Store real values only in Vercel Project Settings, never in committed files.

CRM_ENV=staging
CHILLCRM_DATABASE_ADAPTER=postgres
DATABASE_URL=postgresql://postgres.PROJECT_REF:REPLACE_WITH_PASSWORD@aws-1-us-east-2.pooler.supabase.com:5432/postgres
CHILLCRM_SSLROOTCERT=
CHILLCRM_POSTGRES_STATEMENT_TIMEOUT_MS=8000

APP_BASE_URL=https://chillcrm.app

CHILLCRM_AUTH_REQUIRED=true
SESSION_SECRET=replace_with_generated_high_entropy_secret
SESSION_COOKIE_SECURE=true
AUTH_BOOTSTRAP_ADMIN_EMAIL=replace_with_owner_email
AUTH_BOOTSTRAP_ADMIN_PASSWORD_HASH=replace_with_pbkdf2_password_hash

REMOTE_WRITE_LOCK=true
EXPORT_PACKAGE_ENABLED=false
DOCUMENT_FILE_ACCESS_ENABLED=true

CHILLCRM_SUPABASE_URL=https://ckjbnummsxqcyeahzynz.supabase.co
CHILLCRM_SUPABASE_STORAGE_BUCKET=chillcrm-documents
CHILLCRM_STORAGE_SIGNED_URL_TTL_SECONDS=300
# Server-side only. Required for private signed document access when DOCUMENT_FILE_ACCESS_ENABLED=true.
CHILLCRM_SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key
