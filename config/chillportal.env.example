# ChillPortal environment placeholders.
# Do not commit real secrets, production values, client invite links, provider
# tokens, or live document/auth configuration here.

CHILLPORTAL_ENABLED=false
CHILLPORTAL_ROUTE_PREFIX=/portal

CHILLPORTAL_FEATURE_DASHBOARD=false
CHILLPORTAL_FEATURE_DOCUMENTS=false
CHILLPORTAL_FEATURE_NEXT_STEPS=false
CHILLPORTAL_FEATURE_CLIENT_NOTES=false

# Unknown until explicitly approved and selected.
CHILLPORTAL_PUBLIC_URL=replace_when_approved
CHILLPORTAL_AUTH_PROVIDER=replace_when_selected
CHILLPORTAL_INVITATION_FLOW=replace_when_selected
CHILLPORTAL_DOCUMENT_STORAGE_PROVIDER=replace_when_selected
